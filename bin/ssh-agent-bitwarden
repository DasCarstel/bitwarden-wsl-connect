#!/bin/bash
# Bridge: Windows Bitwarden SSH-Agent Named Pipe -> Unix Socket via npiperelay
# 
# This script creates a bridge between WSL2 and the Bitwarden SSH-Agent running on Windows.
# It uses socat to create a Unix socket and npiperelay to connect to the Windows Named Pipe.
#
# Usage:
#   ssh-agent-bitwarden start     - Start the bridge
#   ssh-agent-bitwarden stop     - Stop the bridge
#   ssh-agent-bitwarden status   - Show bridge status
#   ssh-agent-bitwarden          - List available keys
#   ssh-agent-bitwarden shell   - Start a shell with SSH_AUTH_SOCK set
#
# Setup:
#   - Install socat in WSL: sudo apt install socat
#   - Install npiperelay.exe in Windows: C:\tools\npiperelay.exe
#   - Enable Bitwarden SSH-Agent in Bitwarden Desktop App

set -euo pipefail

WIN_PIPE="//./pipe/openssh-ssh-agent"
SOCK_DIR="$HOME/.ssh/sockets"
SOCK="$SOCK_DIR/bitwarden-agent.sock"
NPIPERELAY="/mnt/c/tools/npiperelay"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

setup_dirs() {
    mkdir -p "$SOCK_DIR"
    chmod 700 "$SOCK_DIR"
}

bridge_running() {
    pgrep -f "npiperelay.exe" >/dev/null 2>&1
}

check_requirements() {
    local missing=0
    
    if [ ! -x "$NPIPERELAY.exe" ]; then
        log_error "npiperelay.exe nicht gefunden: $NPIPERELAY.exe"
        log_error "Bitte installieren: https://github.com/NT-broker/WSL-network-tools/releases"
        missing=1
    fi
    
    if ! command -v socat >/dev/null 2>&1; then
        log_error "socat nicht installiert"
        log_error "Bitte installieren: sudo apt install socat"
        missing=1
    fi
    
    if ! command -v pgrep >/dev/null 2>&1; then
        log_error "procps nicht installiert"
        log_error "Bitte installieren: sudo apt install procps"
        missing=1
    fi
    
    return $missing
}

start_bridge() {
    setup_dirs
    
    if bridge_running; then
        log_info "Bridge läuft bereits"
        return 0
    fi
    
    rm -f "$SOCK"
    
    log_info "Starte Bridge..."
    setsid socat UNIX-LISTEN:"$SOCK,fork,mode=600" EXEC:"$NPIPERELAY.exe -ei -s $WIN_PIPE",nofork,pipes &
    
    sleep 2
    
    if bridge_running; then
        log_info "Bridge gestartet: $SOCK"
        return 0
    else
        log_error "Bridge konnte nicht gestartet werden"
        return 1
    fi
}

stop_bridge() {
    log_info "Stoppe Bridge..."
    pkill -f "npiperelay.exe" 2>/dev/null || true
    pkill -f "socat.*bitwarden" 2>/dev/null || true
    rm -f "$SOCK"
    log_info "Bridge gestoppt"
}

restart_bridge() {
    stop_bridge
    sleep 1
    start_bridge
}

show_status() {
    if bridge_running; then
        log_info "Bridge läuft: $SOCK"
        
        if [ -S "$SOCK" ]; then
            log_info "Socket existiert und ist aktiv"
        else
            log_warn "Socket existiert nicht!"
        fi
    else
        log_info "Bridge läuft nicht"
    fi
}

list_keys() {
    if ! bridge_running; then
        start_bridge || (log_error "Bridge konnte nicht gestartet werden"; exit 1)
    fi
    
    export SSH_AUTH_SOCK="$SOCK"
    exec ssh-add -l
}

shell_with_agent() {
    if ! bridge_running; then
        start_bridge || (log_error "Bridge konnte nicht gestartet werden"; exit 1)
    fi
    
    export SSH_AUTH_SOCK="$SOCK"
    exec "${@:-bash}"
}

usage() {
    cat <<EOF
Bitwarden SSH-Agent Bridge für WSL2

Verwendung: $(basename "$0") [BEFEHL]

Befehle:
    start     - Bridge starten
    stop      - Bridge stoppen
    restart   - Bridge neustarten
    status    - Status anzeigen
    shell     - Shell mit SSH_AUTH_SOCK starten
    check     - Voraussetzungen prüfen
    help      - Diese Hilfe anzeigen

Ohne Argument: Keys auflisten

Umgebungsvariablen:
    SSH_AUTH_SOCK - Pfad zum Unix Socket (wird automatisch gesetzt)

Beispiele:
    $(basename "$0") start          # Bridge starten
    $(basename "$0")              # Keys auflisten
    $(basename "$0") shell bash   # Interaktive Shell
    ssh-add -l                  # SSH-Keys in neuer Shell
    ssh user@server             # Mit SSH verbinden

Weitere Informationen: Siehe README.md und SETUP.md
EOF
}

case "${1:-}" in
    start)
        check_requirements || exit 1
        start_bridge
        ;;
    stop)
        stop_bridge
        ;;
    restart)
        restart_bridge
        ;;
    status)
        show_status
        ;;
    shell)
        shift
        shell_with_agent "$@"
        ;;
    check)
        check_requirements
        ;;
    help|--help|-h)
        usage
        ;;
    "")
        list_keys
        ;;
    *)
        log_error "Unbekannter Befehl: $1"
        usage
        exit 1
        ;;
esac